{
  "name": "empire-fight-sim-3",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.test.json && tsc -p tsconfig.node.json",
    "typecheck:replay": "tsc -p tsconfig.replay.json",
    "test": "vitest run --passWithNoTests --exclude=tests/performance/**",
    "perf": "vitest run tests/performance --passWithNoTests",
    "replay:formation": "vite experiments/formation-replay --host 127.0.0.1 --port 5174",
    "replay:formation:build": "vite build experiments/formation-replay --outDir ../../dist/formation-replay",
    "replay:combat": "vite experiments/combat-replay --host 127.0.0.1 --port 5175",
    "replay:combat:build": "vite build experiments/combat-replay --outDir ../../dist/combat-replay"
  },
  "dependencies": {
    "pixi.js": "8.19.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
